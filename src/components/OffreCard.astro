---
import PbImage from "./PbImage.astro";

interface Props {
    offre: any;
}

const { offre } = Astro.props;

---

<div
    class="offre bg-white shadow-md rounded-lg overflow-hidden hover:shadow-xl transition-all duration-300 border border-gray-200"
    data-favori={offre.favori?.toString()}
>
    {
        offre.image && offre.image.length > 0 && (
            <div class="w-full h-48 overflow-hidden">
                <PbImage record={offre} recordImage={offre.image} />
            </div>
        )
    }
    <div class="p-6">
        <div class="flex justify-between items-start mb-3">
            <h2 class="text-xl font-bold text-gray-800">
                {offre.nomMaison}
            </h2>
            <a href={`/offres/${offre.id}`} class="text-sm text-blue-600 hover:underline ml-4 self-center">Voir plus</a>
        </div>
        <div class="flex items-center gap-4 mt-4 text-sm text-gray-700">

        </div>
        <div
            class="flex justify-between items-center mt-4 pt-4 border-t border-gray-200"
        >
            <p class="text-2xl font-bold text-blue-600">
                {offre.prix}&euro;<span class="text-sm text-gray-500">/mois</span>
            </p>
            <button
                class="favori-btn px-4 py-2 ml-4 rounded-lg text-base font-semibold transition-all duration-300 hover:scale-110"
                aria-label="Marquer comme favori"
            >
                {offre.favori ? "Retirer des favoris" : "Ajouter aux favoris"}
            </button>
        </div>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", () => {
        const cards = document.querySelectorAll(".offre");

        cards.forEach((card) => {
            const button = card.querySelector(".favori-btn");
            if (!button) return;

            const isFavori = card.getAttribute("data-favori") === "true";

            // Définir l'état initial du bouton (la carte reste blanche)
            if (isFavori) {
                button.classList.add("bg-red-500", "text-white");
                if (button.tagName.toLowerCase() === 'button' && button.textContent.trim().length > 1) {
                    button.textContent = 'Retirer des favoris';
                }
            } else {
                button.classList.add("bg-gray-200", "text-gray-600");
                if (button.tagName.toLowerCase() === 'button' && button.textContent.trim().length > 1) {
                    button.textContent = 'Ajouter aux favoris';
                }
            }

            // Gérer le clic sur le bouton — ne modifie que le bouton et l'attribut data-favori
            button.addEventListener("click", () => {
                const currentFavori = card.getAttribute("data-favori") === "true";

                if (currentFavori) {
                    // Retirer des favoris
                    card.setAttribute("data-favori", "false");
                    button.classList.remove("bg-red-500", "text-white");
                    button.classList.add("bg-gray-200", "text-gray-600");
                    if (button.tagName.toLowerCase() === 'button' && button.textContent.trim().length > 1) {
                        button.textContent = 'Ajouter aux favoris';
                    }
                } else {
                    // Ajouter aux favoris
                    card.setAttribute("data-favori", "true");
                    button.classList.remove("bg-gray-200", "text-gray-600");
                    button.classList.add("bg-red-500", "text-white");
                    if (button.tagName.toLowerCase() === 'button' && button.textContent.trim().length > 1) {
                        button.textContent = 'Retirer des favoris';
                    }
                }
            });
        });
    });
</script>