---
import { getImageUrl } from '../backend.mjs';
const {
    record,
    recordImage,
    width = 400,
    height = 300,
} = Astro.props;

const imageURL = await getImageUrl(record, recordImage);

---

{
    imageURL && (
        <img
            src={imageURL}
            alt={record.nomMaison || 'Image'}
            width={width}
            height={height}
            class="w-full h-full object-cover block"
            style="max-width:100%;"
        />
    )
}