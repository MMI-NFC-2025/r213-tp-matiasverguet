---
const { offre } = Astro.props;
import PbImage from "./PbImage.astro";
---

<div class="card">
    <PbImage record={offre} recordImage={offre.images?.[0]} width={400} height={300} />

    <p>{offre.nomMaison}</p>

    <a href={`/offres/${offre.id}`} class="text-sm text-blue-600 hover:underline">Voir plus</a>

    {offre.favori && <span class="favori">★ Favori </span>}
</div>
